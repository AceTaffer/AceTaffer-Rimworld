<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- ========== 三发射手 (Threepeater) ========== -->
  <!-- 继承自 PlantBase，获得植物基础属性。基于豌豆射手修改，一次发射三枚豌豆，精度略降，射速稍快。 -->
  <ThingDef ParentName="PlantBase">
    <!-- 唯一标识符，全局唯一 -->
    <defName>Threepeater</defName>
    <!-- 游戏内显示名称 -->
    <label>threepeater</label>
    <!-- 描述文本 -->
    <description>A powerful plant that fires three peas in a burst. Slightly less accurate but faster than the peashooter. Cannot be harvested, only cut down.</description>
    <!-- 逻辑类，使用原版 Plant 类即可，攻击由组件处理 -->
    <thingClass>Plant</thingClass>
    <!-- 更新频率：Normal 使组件每帧被调用 -->
    <tickerType>Normal</tickerType>

    <!-- ========== 图形设置 ========== -->
    <graphicData>
      <!-- 成熟期贴图路径（需自行放置，建议使用三发射手的独特贴图） -->
      <texPath>Things/Plant/Threepeater/mature</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutPlant</shaderType>
      <drawSize>(1.0,1.2)</drawSize>
    </graphicData>
    <!-- 种植菜单图标路径 -->
    <uiIconPath>UI/Things/Plant_Threepeater</uiIconPath>
    <uiIconScale>1.0</uiIconScale>

    <!-- ========== 基础属性（与豌豆射手基本一致，市场价值略高） ========== -->
    <statBases>
      <MaxHitPoints>60</MaxHitPoints>          <!-- 耐久度 -->
      <Beauty>2</Beauty>                        <!-- 美观度 -->
      <Flammability>0.5</Flammability>          <!-- 易燃性 50% -->
      <WorkToBuild>150</WorkToBuild>             <!-- 种植工作量 -->
      <Nutrition>0</Nutrition>                   <!-- 不可食用 -->
      <MarketValue>200</MarketValue>              <!-- 市场价值更高，体现三发优势 -->
    </statBases>

    <!-- 必须添加 ingestible 块，避免营养值警告，但设为不可食用 -->
    <ingestible>
      <foodType>VegetableOrFruit</foodType>
      <preferability>NeverForNutrition</preferability>
    </ingestible>

    <selectable>true</selectable>
    <pathCost>14</pathCost>                      <!-- 轻微阻挡移动 -->

    <!-- ========== 植物生长参数 ========== -->
    <plant>
      <growDays>1</growDays>                     <!-- 1天成熟 -->
      <!-- 没有 harvestedThingDef，因此不可收获 -->
      <sowMinSkill>0</sowMinSkill>                <!-- 无需种植技能 -->
      <sowTags>
        <li>Ground</li>                           <!-- 可种于地面 -->
        <li>Hydroponic</li>                       <!-- 可种于水培盆 -->
      </sowTags>
      <growMinGlow>0.3</growMinGlow>
      <growOptimalGlow>0.6</growOptimalGlow>
      <fertilitySensitivity>0.5</fertilitySensitivity>
      <dieIfLeafless>true</dieIfLeafless>
      <!-- 生长期贴图 -->
      <immatureGraphicPath>Things/Plant/Threepeater/immature</immatureGraphicPath>
      <visualSizeRange>0.5~1.2</visualSizeRange>
      <topWindExposure>0.4</topWindExposure>
      <purpose>Food</purpose>                     <!-- 归类，但无收获物 -->
      <!-- 研究前置：可持续植物科技 -->
      <sowResearchPrerequisites>
        <li>SustainablePlants</li>
      </sowResearchPrerequisites>
    </plant>

    <!-- ========== 攻击组件 ========== -->
    <comps>
      <li Class="PumpkinShield.CompProperties_PlantShooter">
        <range>25</range>                          <!-- 攻击半径 25 格 -->
        <burstShotCount>3</burstShotCount>        <!-- 每次发射 3 发豌豆（三连发） -->
        <ticksBetweenShots>240</ticksBetweenShots> <!-- 射击间隔 240 ticks ≈ 4 秒 -->
        <projectileDef>Projectile_Pea</projectileDef> <!-- 使用与豌豆射手相同的子弹 -->
        <!-- 精度设为 75% -->
        <accuracyTouch>0.75</accuracyTouch>
        <accuracyShort>0.75</accuracyShort>
        <accuracyMedium>0.75</accuracyMedium>
        <accuracyLong>0.75</accuracyLong>
        <!-- 新增：要求视线检测（不攻击墙后敌人） -->
        <checkLineOfSight>true</checkLineOfSight>
      </li>
    </comps>

    <category>Plant</category>
  </ThingDef>

  <!-- 注：豌豆子弹 Projectile_Pea 已在豌豆射手文件中定义，此处无需重复 -->

</Defs>