<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <ThingDef ParentName="PlantBase">
    <defName>WallNutHologram</defName>
    <label>hologram wall-nut</label>
    <description>A holographic wall-nut. It can be harvested repeatedly for plasteel.</description>
    <thingClass>Plant</thingClass>

    <graphicData>
      <texPath>Things/Plant/WallNut/mature</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutPlant</shaderType>
      <drawSize>(1.2,1.2)</drawSize>
    </graphicData>
    <uiIconPath>UI/Things/Plant_WallNut</uiIconPath>
    <uiIconScale>1.0</uiIconScale>

    <statBases>
      <MaxHitPoints>150</MaxHitPoints>
      <Beauty>0.5</Beauty>
      <Flammability>0</Flammability>
      <WorkToBuild>300</WorkToBuild>
    </statBases>

    <!-- ✅ 显式添加 ingestible 并设置为 NeverForNutrition -->
    <ingestible>
      <preferability>NeverForNutrition</preferability>
    </ingestible>

    <selectable>true</selectable>
    <pathCost>10</pathCost>

    <plant>
      <growDays>5</growDays>
      <harvestAfterGrowth>0.5</harvestAfterGrowth>
      <growMinGlow>0.3</growMinGlow>
      <growOptimalGlow>0.5</growOptimalGlow>
      <fertilitySensitivity>0</fertilitySensitivity>
      <lifespanDaysPerGrowDays>100</lifespanDaysPerGrowDays>
      <harvestWork>100</harvestWork>
      <sowWork>300</sowWork>
      <dieIfLeafless>false</dieIfLeafless>
      <harvestTag>Standard</harvestTag>
      <harvestedThingDef>Plasteel</harvestedThingDef>
      <harvestYield>10</harvestYield>
      <sowMinSkill>0</sowMinSkill>
      <sowTags>
        <li>Ground</li>
        <li>Hydroponic</li>
      </sowTags>
      <topWindExposure>0.1</topWindExposure>
      <immatureGraphicPath>Things/Plant/WallNut/immature</immatureGraphicPath>
      <visualSizeRange>0.5~1.2</visualSizeRange>
      <cavePlantWeight>2</cavePlantWeight>
      <purpose>Food</purpose>
    </plant>

    <category>Plant</category>
  </ThingDef>
</Defs>