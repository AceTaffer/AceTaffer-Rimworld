<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- ========== 卷心菜投手 (Cabbage Thrower) ========== -->
  <ThingDef ParentName="PlantBase">
    <defName>CabbageThrower</defName>
    <label>cabbage thrower</label>
    <description>Throws cabbages over walls, but cannot fire under roofs.</description>
    <thingClass>Plant</thingClass>
    <tickerType>Normal</tickerType>

    <graphicData>
      <texPath>Things/Plant/CabbageThrower/mature</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutPlant</shaderType>
      <drawSize>(1.0,1.2)</drawSize>
    </graphicData>
    <uiIconPath>UI/Things/Plant_CabbageThrower</uiIconPath>
    <uiIconScale>1.0</uiIconScale>

    <statBases>
      <MaxHitPoints>60</MaxHitPoints>
      <Beauty>2</Beauty>
      <Flammability>0.5</Flammability>
      <WorkToBuild>150</WorkToBuild>
      <Nutrition>0</Nutrition>
      <MarketValue>100</MarketValue>
    </statBases>

    <ingestible>
      <foodType>VegetableOrFruit</foodType>
      <preferability>NeverForNutrition</preferability>
    </ingestible>

    <selectable>true</selectable>
    <pathCost>14</pathCost>

    <plant>
      <growDays>1</growDays>
      <sowMinSkill>0</sowMinSkill>
      <sowTags>
        <li>Ground</li>
        <li>Hydroponic</li>
      </sowTags>
      <growMinGlow>0.3</growMinGlow>
      <growOptimalGlow>0.6</growOptimalGlow>
      <fertilitySensitivity>0.5</fertilitySensitivity>
      <dieIfLeafless>true</dieIfLeafless>
      <immatureGraphicPath>Things/Plant/CabbageThrower/immature</immatureGraphicPath>
      <visualSizeRange>0.5~1.2</visualSizeRange>
      <topWindExposure>0.4</topWindExposure>
      <purpose>Food</purpose>
      <sowResearchPrerequisites>
        <li>ThrowingPlants</li>
      </sowResearchPrerequisites>
    </plant>

    <comps>
      <li Class="PumpkinShield.CompProperties_PlantShooter">
        <range>25</range>
        <burstShotCount>1</burstShotCount>
        <ticksBetweenShots>240</ticksBetweenShots>
        <projectileDef>Bullet_Cabbage</projectileDef>
        <!-- 精准度 100% -->
        <accuracyTouch>1.0</accuracyTouch>
        <accuracyShort>1.0</accuracyShort>
        <accuracyMedium>1.0</accuracyMedium>
        <accuracyLong>1.0</accuracyLong>
      </li>
    </comps>

    <category>Plant</category>
  </ThingDef>

