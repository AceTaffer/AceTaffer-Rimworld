<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!-- 腰带挂灯的光源（不可见） -->
	<ThingDef>
		<defName>BeltLampLightSource</defName>
		<label>light source (invisible)</label>
		<description>Invisible light source for belt lamp.</description>
		<thingClass>ThingWithComps</thingClass>
		<!-- 修正点：必须为 ThingWithComps 才能使用组件 -->
		<graphicData>
			<!-- 需要放置一个透明PNG在此路径：Textures/Things/Item/Transparent.png -->
			<texPath>Things/Item/Transparent</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>Cutout</shaderType>
		</graphicData>
		<tickerType>Normal</tickerType>
		<altitudeLayer>Item</altitudeLayer>
		<selectable>false</selectable>
		<neverMultiSelect>true</neverMultiSelect>
		<drawGUIOverlay>false</drawGUIOverlay>
		<!-- 发光组件 -->
		<comps>
			<li Class="CompProperties_Glower">
				<glowRadius>7</glowRadius>
				<glowColor>(255,255,200)</glowColor>
			</li>
		</comps>
	</ThingDef>
</Defs>