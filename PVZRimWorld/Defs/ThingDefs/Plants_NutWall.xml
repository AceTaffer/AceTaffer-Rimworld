<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <ThingDef ParentName="PlantBase">
    <defName>NutWallPlant</defName>
    <label>nut wall plant</label>
    <description>A sturdy plant that yields wood after 4 days.</description>
    <thingClass>Plant</thingClass>
    <graphicData>
      <texPath>Things/Plant/NutWall/mature</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutPlant</shaderType>
      <drawSize>(1.1,1.2)</drawSize>
    </graphicData>
    <uiIconPath>UI/Things/Plant_NutWall</uiIconPath>
    <uiIconScale>1.0</uiIconScale>
    <statBases>
      <MaxHitPoints>80</MaxHitPoints>
      <Beauty>1.0</Beauty>
      <Flammability>0.4</Flammability>
      <WorkToBuild>300</WorkToBuild>
      <Nutrition>0</Nutrition>
    </statBases>
    <ingestible>
      <foodType>VegetableOrFruit</foodType>
      <preferability>NeverForNutrition</preferability>
    </ingestible>
    <selectable>true</selectable>
    <pathCost>12</pathCost>
    <plant>
      <growDays>4</growDays>
      <harvestedThingDef>WoodLog</harvestedThingDef>
      <harvestYield>10</harvestYield>
      <sowMinSkill>4</sowMinSkill>
      <sowTags>
        <li>Ground</li>
      </sowTags>
      <immatureGraphicPath>Things/Plant/NutWall/immature</immatureGraphicPath>
      <growMinGlow>0.4</growMinGlow>
      <growOptimalGlow>0.7</growOptimalGlow>
      <fertilitySensitivity>0.6</fertilitySensitivity>
      <dieIfLeafless>true</dieIfLeafless>
      <visualSizeRange>0.5~1.2</visualSizeRange>
      <topWindExposure>0.3</topWindExposure>
      <purpose>Food</purpose>
      <!-- 研究前置：种植植物科技 -->
      <sowResearchPrerequisites>
        <li>PlantCultivation</li>
      </sowResearchPrerequisites>
    </plant>
    <category>Plant</category>
  </ThingDef>
</Defs>