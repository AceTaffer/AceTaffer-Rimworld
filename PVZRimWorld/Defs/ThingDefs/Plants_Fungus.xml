<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <ThingDef ParentName="PlantBase">
    <defName>BigFungus</defName>
    <label>large puff mushroom</label>
    <description>A large fungus that can be cultivated. Grows best in darkness.</description>
    <thingClass>Plant</thingClass>
    <graphicData>
      <texPath>Things/Plant/FungusBig/mature</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutPlant</shaderType>
      <drawSize>(1.0,1.0)</drawSize>
    </graphicData>
    <uiIconPath>UI/Things/Plant_FungusBig</uiIconPath>
    <uiIconScale>1.0</uiIconScale>
    <statBases>
      <MaxHitPoints>45</MaxHitPoints>
      <Beauty>-2.0</Beauty>
      <Flammability>0.8</Flammability>
      <WorkToBuild>200</WorkToBuild>
      <Nutrition>0.05</Nutrition>
    </statBases>
    <ingestible>
      <foodType>VegetableOrFruit</foodType>
      <preferability>NeverForNutrition</preferability>
    </ingestible>
    <selectable>true</selectable>
    <pathCost>14</pathCost>
    <plant>
      <growDays>6</growDays>
      <sowTags>
        <li>Ground</li>
      </sowTags>
      <sowMinSkill>4</sowMinSkill>
      <harvestedThingDef>RawFungus</harvestedThingDef>
      <harvestYield>12</harvestYield>
      <growMinGlow>0</growMinGlow>
      <growOptimalGlow>0</growOptimalGlow>
      <fertilitySensitivity>0.5</fertilitySensitivity>
      <dieIfLeafless>true</dieIfLeafless>
      <topWindExposure>0.0</topWindExposure>
      <immatureGraphicPath>Things/Plant/FungusBig/immature</immatureGraphicPath>
      <visualSizeRange>0.4~1.0</visualSizeRange>
      <purpose>Food</purpose>
      <!-- 研究前置：种植植物科技 -->
      <sowResearchPrerequisites>
        <li>PlantCultivation</li>
      </sowResearchPrerequisites>
    </plant>
    <category>Plant</category>
  </ThingDef>
</Defs>