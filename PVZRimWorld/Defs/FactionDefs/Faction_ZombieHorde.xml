<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- ========== 僵尸群 (Zombie Horde) ========== -->
  <FactionDef>
    <defName>ZombieHorde</defName>
    <label>zombie horde</label>
    <description>没人知道他们是怎么来的，也不知道它存在了多久……</description>
    
    <hidden>true</hidden>
    <requiredCountAtGameStart>1</requiredCountAtGameStart>
    <maxConfigurableAtWorldCreation>1</maxConfigurableAtWorldCreation>
    <configurationListOrderPriority>900</configurationListOrderPriority>
    <factionIconPath>World/WorldObjects/Expanding/Mechanoids</factionIconPath>
    <techLevel>Neolithic</techLevel>
    <humanlikeFaction>true</humanlikeFaction>
    <backstoryFilters>
      <li>
        <categories>
          <li>Tribal</li>
        </categories>
      </li>
    </backstoryFilters>
    <factionNameMaker>NamerFactionTribal</factionNameMaker>
    <permanentEnemy>true</permanentEnemy>
    <hostileToFactionlessHumanlikes>true</hostileToFactionlessHumanlikes>
    <autoFlee>false</autoFlee>
    <canUseAvoidGrid>false</canUseAvoidGrid>
    <raidCommonalityFromPointsCurve>
      <points>
        <li>(0, 0)</li>
      </points>
    </raidCommonalityFromPointsCurve>
    <maxPawnCostPerTotalPointsCurve>
      <points>
        <li>(100,100)</li>
        <li>(10000,10000)</li>
      </points>
    </maxPawnCostPerTotalPointsCurve>
    <pawnGroupMakers>
      <li>
        <kindDef>Combat</kindDef>
        <commonality>1</commonality>
        <options>
          <Zombie_Regular>10</Zombie_Regular>
          <Zombie_Elite>5</Zombie_Elite>
          <Zombie_Joker>2</Zombie_Joker>
        </options>
      </li>
    </pawnGroupMakers>
    <colorSpectrum>
      <li>(0.6,0.8,0.4)</li>
    </colorSpectrum>
    <pawnSingular>zombie</pawnSingular>
    <pawnsPlural>zombies</pawnsPlural>
    <settlementTexturePath>World/WorldObjects/DefaultSettlement</settlementTexturePath>
    <allowedArrivalTemperatureRange>-100~200</allowedArrivalTemperatureRange>
    <raidLootValueFromPointsCurve>
      <points>
        <li>(35, 15)</li>
        <li>(100, 120)</li>
        <li>(1000, 500)</li>
        <li>(2000, 800)</li>
        <li>(4000, 1000)</li>
      </points>
    </raidLootValueFromPointsCurve>
    <canGenerateQuestSites>false</canGenerateQuestSites>
  </FactionDef>
</Defs>